# Flask Settings
FLASK_APP=backend/app.py
FLASK_ENV=development
SECRET_KEY=replace_with_a_very_secure_random_string_in_production
PORT=5000

# Database Settings
# For local MySQL: mysql+pymysql://username:password@localhost:3306/network_monitor
# For docker-compose: mysql+pymysql://root:rootpassword@db:3306/network_monitor
DATABASE_URL=mysql+pymysql://root:rootpassword@localhost:3306/network_monitor

# Packet Sniffer Configuration
# Leave blank to auto-detect the default interface, or specify an interface (e.g. eth0, Wi-Fi, Npcap Loopback Adapter)
SNIFFER_INTERFACE=
# Simulation mode: set to TRUE to simulate network traffic instead of binding to raw sockets (recommended for Windows testing without NPCap, or Docker environments)
SNIFFER_SIMULATION=TRUE
# Sleep interval between simulated packets in seconds (float)
SNIFFER_SIMULATION_INTERVAL=0.5

# Email/SMTP Configuration (for Threat Alerts)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=TRUE
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=threat-alerts@example.com
ADMIN_EMAIL=admin-alerts@example.com
