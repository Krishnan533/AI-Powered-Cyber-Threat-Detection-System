# SHIELD_IDS Environment Configuration Template
# Copy this file to .env and configure secret parameters prior to launching.

# App Execution Mode: 'development', 'production', or 'testing'
FLASK_ENV=production
FLASK_APP=backend/app.py
SECRET_KEY=replace_with_a_very_secure_string_9018230

# Database Connection URI
# SQLite (Development Default): sqlite:///network_monitor.db
# PostgreSQL (Production Default): postgresql://user:password@localhost:5432/network_monitor
DATABASE_URL=sqlite:///network_monitor.db

# Packet Capture Sniffer Daemon Options
# SNIFFER_SIMULATION=TRUE generates simulated network traffic (for cloud platforms without raw socket permissions)
# SNIFFER_SIMULATION=FALSE captures real live interface traffic (requires Administrator / Root / sudo)
SNIFFER_SIMULATION=TRUE
SNIFFER_INTERFACE=eth0

# SMTP Email Alert Service Setup
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=TRUE
MAIL_USE_SSL=FALSE
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=threat-alerts@example.com
ADMIN_EMAIL=admin-alerts@example.com
SEND_EMAIL_NOTIFICATIONS=TRUE

# Default Bootstrap Admin User Credentials
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=AdminPass123!
DEFAULT_ANALYST_USERNAME=analyst
DEFAULT_ANALYST_PASSWORD=AnalystPass456!
DEFAULT_VIEWER_USERNAME=viewer
DEFAULT_VIEWER_PASSWORD=ViewerPass789!
